{
	"info": {
		"_postman_id": "omega-world-phase-6-audit-v2",
		"name": "OMEGA World - Phase 6 API Audit (Improved)",
		"description": "Full testing suite for OMEGA World Backend. Now with resilient catalog checking for empty vendor states.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Get Active Zones",
			"request": {
				"method": "GET",
				"header": [
					{ "key": "Accept", "value": "application/json" }
				],
				"url": {
					"raw": "{{base_url}}/api/zones",
					"host": ["{{base_url}}"],
					"path": ["api", "zones"]
				}
			},
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status code is 200', () => pm.response.to.have.status(200));",
							"pm.test('Response has data array', () => pm.expect(pm.response.json().data).to.be.an('array'));"
						]
					}
				}
			]
		},
		{
			"name": "2. Get Vendors by Zone",
			"request": {
				"method": "GET",
				"header": [
					{ "key": "Accept", "value": "application/json" }
				],
				"url": {
					"raw": "{{base_url}}/api/vendors?zone_id={{active_zone_id}}",
					"host": ["{{base_url}}"],
					"path": ["api", "vendors"],
					"query": [{ "key": "zone_id", "value": "{{active_zone_id}}" }]
				}
			},
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status code is 200', () => pm.response.to.have.status(200));",
							"const jsonData = pm.response.json();",
							"if (jsonData.data.length > 0) {",
							"    pm.test('Vendor has required Phase 6 fields', () => {",
							"        const vendor = jsonData.data[0];",
							"        pm.expect(vendor).to.have.property('primary_category');",
							"        pm.expect(vendor).to.have.property('whatsapp_number');",
							"    });",
							"}"
						]
					}
				}
			]
		},
		{
			"name": "3. Get Enriched Vendor Catalog",
			"request": {
				"method": "GET",
				"header": [
					{ "key": "Accept", "value": "application/json" }
				],
				"url": {
					"raw": "{{base_url}}/api/vendors/{{active_vendor_id}}/catalog",
					"host": ["{{base_url}}"],
					"path": ["api", "vendors", "{{active_vendor_id}}", "catalog"]
				}
			},
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status code is 200', () => pm.response.to.have.status(200));",
							"pm.test('Catalog Structure is GEI Ready', () => {",
							"    const data = pm.response.json().data;",
							"    pm.expect(data).to.have.property('categories');",
							"    pm.expect(data).to.have.property('whatsapp_number');",
							"    ",
							"    if (data.categories && data.categories.length > 0) {",
							"        pm.expect(data.categories[0]).to.have.property('products');",
							"    } else {",
							"        console.warn('OMEGA Audit: Catalog is empty. Ingestion might be pending.');",
							"    }",
							"});"
						]
					}
				}
			]
		}
	],
	"variable": [
		{ "key": "base_url", "value": "http://localhost:8000", "type": "string" },
		{ "key": "active_zone_id", "value": "1", "type": "string" },
		{ "key": "active_vendor_id", "value": "1", "type": "string" }
	]
}
